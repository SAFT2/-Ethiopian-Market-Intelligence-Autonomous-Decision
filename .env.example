DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/market_intelligence
SCRAPER_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
REQUEST_TIMEOUT_SECONDS=20
JIJI_MAX_PAGES=3
MAX_RETRIES=3
SLEEP_SECONDS_BETWEEN_REQUESTS=1.0

# Backend hardening
CREATE_TABLES_ON_STARTUP=false
ML_SERVICE_BASE_URL=http://localhost:8010
ML_REQUEST_TIMEOUT_SECONDS=10
ML_REQUEST_MAX_RETRIES=3
ML_CIRCUIT_FAILURE_THRESHOLD=5
ML_CIRCUIT_OPEN_SECONDS=30
CORS_ALLOW_ORIGINS=http://localhost:5173
